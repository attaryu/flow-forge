{"nodes": [{"id": "docs_architecture_decision_multi_tenancy_isolation", "label": "Multi-Tenancy Isolation", "file_type": "concept", "rationale": "Every table has a tenant_id (organization_id) foreign key. All queries filter by tenant automatically for database level isolation.", "source_file": "docs/architecture-decision.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_decision_per_node_execution_model", "label": "Per-Node Execution Model", "file_type": "concept", "rationale": "Each workflow step is a separate BullMQ job. The worker orchestrates transitions rather than enqueuing the entire workflow, supporting non-blocking delays, retry granularity, and crash resilience.", "source_file": "docs/architecture-decision.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_decision_separate_job_queues", "label": "Separate Job Queues", "file_type": "concept", "rationale": "Separation into triggerQueue and executionQueue ensures scheduled triggers are processed reliably and don't get delayed by slow execution jobs.", "source_file": "docs/architecture-decision.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_decision_react_flow_editor", "label": "React Flow Frontend Editor", "file_type": "concept", "rationale": "React Flow (xyflow) is selected over alternatives because it is native React and makes conditional branching native and fast to implement.", "source_file": "docs/architecture-decision.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_decision_dag_validation", "label": "DAG Validation", "file_type": "concept", "rationale": "Uses graphology + graphology-dag for design-time cycle detection and topological order analysis.", "source_file":